# Copy this file to .env.local and fill in your keys.
# All are read server-side by the /api/copilot route.

# Anthropic — copilot chat, filter tools, and query expansion for similar-paper search.
ANTHROPIC_API_KEY=

# OpenAI — query embeddings for similar-paper search (must be the same model the
# corpus was embedded with: text-embedding-3-small).
OPENAI_API_KEY=

# turbopuffer — hybrid (vector + BM25) search over the paper embeddings.
TURBOPUFFER_API_KEY=
TURBOPUFFER_REGION=
TURBOPUFFER_NAMESPACE=
